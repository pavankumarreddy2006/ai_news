# ==========================================================
# COMPLETE .ENV CONFIGURATION
# PERSONAL AI NEWS PLATFORM
# ==========================================================

# ==========================================================
# APP INFORMATION
# ==========================================================
APP_NAME=AI News Platform
APP_ENV=development
APP_DEBUG=true
APP_VERSION=1.0.0

# ==========================================================
# FRONTEND + BACKEND URLS
# ==========================================================
FRONTEND_URL=http://localhost:5173
FRONTEND_PREVIEW_URL=
BACKEND_URL=http://127.0.0.1:10000
CORS_ALLOWED_ORIGINS=http://localhost:5173
VITE_API_URL=http://localhost:10000
VITE_API_BASE_URL=http://localhost:10000
VITE_WS_URL=ws://localhost:10000

# ==========================================================
# DATABASE
# ==========================================================
DATABASE_URL=postgresql://USERNAME:PASSWORD@localhost/ai_news

# ==========================================================
# SECURITY
# ==========================================================
SECRET_KEY=CHANGE_THIS_SECRET_KEY
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ==========================================================
# REDDIT API
# ==========================================================
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=ai-news-platform

# ==========================================================
# GITHUB API
# ==========================================================
GITHUB_TOKEN=

# ==========================================================
# YOUTUBE API
# ==========================================================
YOUTUBE_API_KEY=

# ==========================================================
# PRODUCT HUNT API
# ==========================================================
PRODUCTHUNT_TOKEN=

# ==========================================================
# OPENAI API
# ==========================================================
OPENAI_API_KEY=

# ==========================================================
# OPENROUTER API
# ==========================================================
OPENROUTER_API_KEY=

# ==========================================================
# TELEGRAM BOT API
# ==========================================================
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_DIGEST_HOUR=8
TELEGRAM_DIGEST_MINUTE=0
TELEGRAM_DIGEST_TIMEZONE=Asia/Calcutta

# ==========================================================
# RSS FEEDS
# ==========================================================
OPENAI_RSS=https://openai.com/news/rss.xml
TECHCRUNCH_AI_RSS=https://techcrunch.com/category/artificial-intelligence/feed/
VERGE_AI_RSS=https://www.theverge.com/ai-artificial-intelligence/rss/index.xml
ANTHROPIC_RSS=https://www.anthropic.com/news/rss.xml
HUGGINGFACE_RSS=https://huggingface.co/blog/feed.xml
GOOGLE_AI_RSS=https://blog.google/technology/ai/rss/
DEEPMIND_RSS=https://deepmind.google/discover/blog/rss.xml
NVIDIA_AI_RSS=https://blogs.nvidia.com/blog/category/ai/feed/

# ==========================================================
# REDDIT SUBREDDITS
# ==========================================================
REDDIT_SUBREDDITS=artificial,OpenAI,ChatGPT,MachineLearning,singularity,LocalLLaMA,StableDiffusion,ArtificialInteligence,ClaudeAI,AItools,Futurology,technology

# ==========================================================
# GITHUB TOPICS
# ==========================================================
GITHUB_TOPICS=ai,llm,agents,rag,automation,openai,langchain,generative-ai,machine-learning

# ==========================================================
# GOOGLE SEARCH QUERIES
# ==========================================================
GOOGLE_SEARCHES=latest AI news,trending AI tools,best free AI tools,AI coding tools,AI video tools,AI productivity tools,AI startups,viral AI tools,AI workflows

# ==========================================================
# YOUTUBE CHANNELS
# ==========================================================
YOUTUBE_CHANNELS=Two Minute Papers,Matt Wolfe,AI Explained,Fireship,NetworkChuck,Liam Ottley,Wes Roth,The AI Grid

# ==========================================================
# AI BLOGS
# ==========================================================
AI_BLOGS=OpenAI Blog,Anthropic Blog,Google AI Blog,DeepMind Blog,NVIDIA AI Blog,Hugging Face Blog,Stability AI Blog,Midjourney Updates,Perplexity Blog

# ==========================================================
# TECH NEWS SOURCES
# ==========================================================
TECH_NEWS=TechCrunch AI,The Verge AI,VentureBeat AI,Ars Technica AI,Wired AI,Analytics India Magazine,Towards Data Science,AI News

# ==========================================================
# AI TOOL SOURCES
# ==========================================================
AI_TOOL_SOURCES=Futurepedia,There's An AI For That,Product Hunt,GitHub,Reddit

# ==========================================================
# SCHEDULER SETTINGS
# ==========================================================
FETCH_INTERVAL_MINUTES=30
DELETE_OLD_NEWS_HOURS=48
NEWS_REFRESH_MINUTES=30
CLEANUP_HOURS=48

# ==========================================================
# REALTIME SETTINGS
# ==========================================================
ENABLE_WEBSOCKETS=true
ENABLE_REALTIME_UPDATES=true
ENABLE_BACKGROUND_JOBS=true
ENABLE_LIVE_UPDATES=true

# ==========================================================
# CACHE SETTINGS
# ==========================================================
ENABLE_CACHE=true
CACHE_TTL_SECONDS=1800

# ==========================================================
# AI PROCESSING SETTINGS
# ==========================================================
ENABLE_AI_SUMMARIZATION=true
ENABLE_SIMPLE_ENGLISH=true
ENABLE_AI_RANKING=true
AI_RANKING_KEYWORDS=GPT,OpenAI,Claude,Gemini,Llama,AI Agent,AI Automation,AI Workflow,AI Startup,AI Coding
MAX_NEWS_ITEMS_PER_SOURCE=12
REQUEST_TIMEOUT_SECONDS=12

# ==========================================================
# TELEGRAM SETTINGS
# ==========================================================
ENABLE_TELEGRAM_NOTIFICATIONS=true
TELEGRAM_SUMMARY_TIME=08:00

# ==========================================================
# SEARCH SETTINGS
# ==========================================================
ENABLE_SMART_SEARCH=true
SEARCH_RESULTS_LIMIT=20

# ==========================================================
# FRONTEND FEATURES
# ==========================================================
ENABLE_DARK_MODE=true
ENABLE_LISTEN_SUMMARY=true
ENABLE_LIVE_FEED=true
ENABLE_TRENDING_SECTION=true
ENABLE_AI_TOOLS_DIRECTORY=true

# ==========================================================
# SEO SETTINGS
# ==========================================================
SITE_NAME=AI News Platform
SITE_DESCRIPTION=Personal AI News and AI Tools Dashboard
SITE_KEYWORDS=AI News,AI Tools,ChatGPT,OpenAI,Claude,Gemini,AI Automation,AI Workflows

# ==========================================================
# PERFORMANCE SETTINGS
# ==========================================================
ENABLE_IMAGE_OPTIMIZATION=true
ENABLE_LAZY_LOADING=true
ENABLE_CODE_SPLITTING=true

# ==========================================================
# LOGGING
# ==========================================================
LOG_LEVEL=INFO
ENABLE_ERROR_LOGGING=true

# ==========================================================
# DEPLOYMENT
# ==========================================================
RENDER=true
ENVIRONMENT=development
